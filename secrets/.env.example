# Telegram
TELEGRAM_BOT_TOKEN=

# Optional defaults
WEBHOOK_DEFAULT_URL=

# VK (сообщество -> стена)
VK_ACCESS_TOKEN=
# Если при постинге с фото получаешь ошибку VK "Group authorization failed ... unavailable with group auth",
# добавь user-токен (полученный от пользователя с правами в сообществе) для загрузки фото:
VK_USER_ACCESS_TOKEN=
VK_GROUP_ID=229926764

# Instagram Graph API (Business/Creator)
IG_ACCESS_TOKEN=
IG_USER_ID=
IG_GRAPH_VERSION=v20.0

# MAX (через API-шлюз, если используешь)
MAX_API_TOKEN=
MAX_API_BASE=https://app.api-messenger.com/max-v1
